{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "CPU-M",
  "version": "0.1.5",
  "identifier": "com.cpum.desktop",
  "build": {
    "beforeDevCommand": "pnpm dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "pnpm build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "CPU-M",
        "width": 1150,
        "height": 760,
        "minWidth": 940,
        "minHeight": 620,
        "center": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQzMDAzOTRENkZBOERGRkUKUldUKzM2aHZUVGtBMDV5N1lsUzBjKyt4N25SK3NBKzRLangzclVuY3dvT1BNYkFDQXF1b0oxcTkK",
      "endpoints": [
        "https://github.com/metesahankurt/CPU-M/releases/latest/download/latest.json"
      ],
      "windows": {
        "installMode": "passive"
      }
    }
  }
}
